@inherits LayoutComponentBase
@inject NavigationManager Nav

@using MediatR
@using Mms.Application.Companies.Queries
@inject IMediator Mediator

<MudThemeProvider Theme="AppTheme.Default" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">Robotia AGM Pro</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <UserMenu />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive">
        <MudDrawerHeader>
            @if (_drawerOpen && !string.IsNullOrEmpty(_logoPath))
            {
                <div style="text-align:center; width:100%;">
                    <img src="@_logoPath" alt="Logo" style="max-height:60px; max-width:180px; object-fit:contain;" />
                </div>
            }
            else if (_drawerOpen)
            {
                <MudText Typo="Typo.subtitle1" Style="color:#1a3a5c;font-weight:600">MMS</MudText>
            }
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <div class="pa-4" style="height:calc(100vh - 64px);overflow-y:auto;">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string? _logoPath;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var company = await Mediator.Send(new GetCompanyQuery());
            if (company != null)
            {
                _logoPath = company.LogoPath;
            }
        }
        catch { /* ignore if DB not ready */ }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
