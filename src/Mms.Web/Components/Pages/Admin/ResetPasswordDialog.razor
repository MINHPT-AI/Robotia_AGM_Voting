@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Key" Class="mr-2" />
            Đặt lại mật khẩu — @UserName
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newPassword" Label="Mật khẩu mới *"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_confirmPassword" Label="Xác nhận mật khẩu *"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined" Class="mb-3" />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_saving">Huỷ</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="_saving">
            @(_saving ? "Đang xử lý..." : "Đặt lại mật khẩu")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid UserId { get; set; }
    [Parameter] public string UserName { get; set; } = string.Empty;

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _saving;
    private string? _errorMessage;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _errorMessage = null;

        if (_newPassword != _confirmPassword)
        {
            _errorMessage = "Mật khẩu xác nhận không khớp";
            return;
        }

        _saving = true;
        try
        {
            await Mediator.Send(new AdminResetPasswordCommand(UserId, _newPassword));
            Snackbar.Add($"Đã đặt lại mật khẩu cho {UserName}", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Mms.Application.Common.Exceptions.ValidationException ex)
        {
            _errorMessage = string.Join(" | ", ex.Errors.SelectMany(e => e.Value));
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally { _saving = false; }
    }
}
