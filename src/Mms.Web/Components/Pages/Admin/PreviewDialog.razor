@using MediatR
@using Mms.Application.Meetings.Dtos
@using Mms.Application.Meetings.Queries
@using Mms.Application.Templates
@using Mms.Domain.Entities
@using MudBlazor
@using Microsoft.JSInterop

@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        <MudSelect T="Guid?" Label="Chọn cuộc họp để xem trước" Value="@SelectedMeetingId" ValueChanged="OnMeetingChanged" Placeholder="-- Dữ liệu mẫu mặc định --" Clearable="true" Variant="Variant.Outlined">
            @foreach (var meeting in _meetings)
            {
                <MudSelectItem T="Guid?" Value="@meeting.Id">@meeting.Title (@meeting.MeetingDate.ToString("dd/MM/yyyy"))</MudSelectItem>
            }
        </MudSelect>

        <MudPaper Class="pa-4 mt-4 bg-light" Elevation="0">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Dữ liệu sẽ được áp dụng:</MudText>
            @if (SelectedMeetingId.HasValue)
            {
                var m = _meetings.FirstOrDefault(x => x.Id == SelectedMeetingId.Value);
                <MudText Typo="Typo.body2"><b>Cuộc họp:</b> @m?.Title</MudText>
                <MudText Typo="Typo.body2"><b>Ngày họp:</b> @m?.MeetingDate.ToString("dd/MM/yyyy HH:mm")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Success" Class="mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />
                    Hệ thống sẽ lấy thông tin Công ty, Cuộc họp và 1 Cổ đông thực tế để tạo Preview.
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.body2"><b>Tên CT:</b> CÔNG TY CỔ PHẦN MẪU</MudText>
                <MudText Typo="Typo.body2"><b>Cổ đông:</b> Nguyễn Văn A</MudText>
                <MudText Typo="Typo.body2"><b>Số CP:</b> 10,000</MudText>
                <MudText Typo="Typo.body2" Color="Color.Warning" Class="mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />
                    Đang dùng dữ liệu giả định. Hãy chọn 1 cuộc họp để xem dữ liệu thực.
                </MudText>
            }
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="PreviewPdf" Disabled="@_isPreviewing">
            @if (_isPreviewing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                <MudText Class="ms-2">Đang tạo PDF...</MudText>
            }
            else
            {
                <MudText>Xem trước PDF &rarr;</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter] public string HtmlContent { get; set; } = string.Empty;
    [Parameter] public TemplateDetailDto? Template { get; set; }

    private List<MeetingListItemDto> _meetings = new();
    private Guid? SelectedMeetingId { get; set; }
    private bool _isPreviewing = false;

    protected override async Task OnInitializedAsync()
    {
        var result = await Mediator.Send(new GetMeetingsQuery(PageSize: 100));
        _meetings = result.Items.ToList();
        
        if (_meetings.Any())
        {
            SelectedMeetingId = _meetings.First().Id;
        }
    }

    private void OnMeetingChanged(Guid? meetingId)
    {
        SelectedMeetingId = meetingId;
    }

    private async Task PreviewPdf()
    {
        try
        {
            _isPreviewing = true;
            
            // Build margins object for the query
            var query = new PreviewTemplateHtmlQuery(
                HtmlContent, 
                SelectedMeetingId,
                Template?.MarginTop ?? 2f,
                Template?.MarginBottom ?? 2f,
                Template?.MarginLeft ?? 3f,
                Template?.MarginRight ?? 2f
            );
            
            var pdfBytes = await Mediator.Send(query);
            
            // Convert to base64 string — JS openPdfInNewTab expects a base64 string, not raw bytes
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("openPdfInNewTab", base64);
            
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tạo Preview: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isPreviewing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
