@page "/change-password"
@attribute [Authorize]
@using Mms.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserMgr
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Đổi mật khẩu — MMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">
                    @(_mustChange ? "Bạn cần đổi mật khẩu trước khi tiếp tục" : "Đổi mật khẩu")
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <EditForm Model="_model" OnValidSubmit="HandleChange">
                <DataAnnotationsValidator />
                <MudTextField @bind-Value="_model.CurrentPassword"
                              Label="Mật khẩu hiện tại"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Class="mb-3"
                              For="@(() => _model.CurrentPassword)" />
                <MudTextField @bind-Value="_model.NewPassword"
                              Label="Mật khẩu mới (tối thiểu 8 ký tự)"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Class="mb-3"
                              For="@(() => _model.NewPassword)" />
                <MudTextField @bind-Value="_model.ConfirmPassword"
                              Label="Xác nhận mật khẩu mới"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              For="@(() => _model.ConfirmPassword)" />
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="_processing">
                    @(_processing ? "Đang xử lý..." : "ĐỔI MẬT KHẨU")
                </MudButton>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private ChangePasswordModel _model = new();
    private bool _processing = false;
    private bool _mustChange = false;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        _mustChange = state.User.FindFirst("must_change_password")?.Value == "true"
                   || state.User.Identity?.IsAuthenticated == false;
    }

    private async Task HandleChange()
    {
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            Snackbar.Add("Mật khẩu xác nhận không khớp", Severity.Error);
            return;
        }
        if (_model.NewPassword == _model.CurrentPassword)
        {
            Snackbar.Add("Mật khẩu mới phải khác mật khẩu cũ", Severity.Error);
            return;
        }

        _processing = true;
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = await UserMgr.GetUserAsync(state.User);
        if (user is null) { Nav.NavigateTo("/login", forceLoad: true); return; }

        var result = await UserMgr.ChangePasswordAsync(user, _model.CurrentPassword, _model.NewPassword);
        if (result.Succeeded)
        {
            user.MustChangePassword = false;
            await UserMgr.UpdateAsync(user);
            Snackbar.Add("Đổi mật khẩu thành công!", Severity.Success);
            Nav.NavigateTo("/");
        }
        else
        {
            var errors = string.Join("; ", result.Errors.Select(e => e.Description));
            Snackbar.Add($"Lỗi: {errors}", Severity.Error);
        }
        _processing = false;
    }

    public class ChangePasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string CurrentPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Tối thiểu 8 ký tự")]
        public string NewPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
