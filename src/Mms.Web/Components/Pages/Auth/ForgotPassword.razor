@page "/forgot-password"
@layout EmptyLayout
<PageTitle>Quên mật khẩu — MMS</PageTitle>

<MudCard Style="width:400px">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Quên mật khẩu</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (_sent)
        {
            <MudAlert Severity="Severity.Success">
                Nếu email tồn tại trong hệ thống, link phục hồi đã được gửi.
            </MudAlert>
        }
        else
        {
            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                          InputType="InputType.Email" Class="mb-4" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" OnClick="Submit">
                GỬI LINK PHỤC HỒI
            </MudButton>
        }
        <MudLink Href="/login" Class="d-block mt-3 text-center" Typo="Typo.body2">
            ← Quay lại đăng nhập
        </MudLink>
    </MudCardContent>
</MudCard>

@code {
    private string _email = string.Empty;
    private bool _sent = false;

    private void Submit()
    {
        // TODO Phase-future: send email via SMTP
        _sent = true;
    }
}
